{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Implementation Plan Graph",
  "description": "Derived DAG and wave model for implementation plan contract execution.",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "stage",
    "iteration_id",
    "nodes",
    "edges",
    "waves"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string",
      "const": "implementation"
    },
    "iteration_id": {
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "scope_kind",
          "depth",
          "can_run_in_parallel",
          "conflict_group"
        ],
        "properties": {
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "scope_kind": {
            "type": "string",
            "enum": [
              "experiment",
              "project_wide"
            ]
          },
          "depth": {
            "type": "integer",
            "minimum": 0
          },
          "can_run_in_parallel": {
            "type": "boolean"
          },
          "conflict_group": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "waves": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "wave",
          "tasks"
        ],
        "properties": {
          "wave": {
            "type": "integer",
            "minimum": 1
          },
          "tasks": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
