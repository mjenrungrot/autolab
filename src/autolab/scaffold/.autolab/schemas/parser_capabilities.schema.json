{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ParserCapabilities",
  "type": "object",
  "required": [
    "schema_version",
    "iteration_id",
    "parser",
    "supported_metrics",
    "output_contract",
    "generated_at"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "iteration_id": {"type": "string", "minLength": 1},
    "parser": {
      "type": "object",
      "required": ["kind", "locator"],
      "properties": {
        "kind": {"type": "string", "enum": ["python", "command"]},
        "locator": {"type": "string", "minLength": 1},
        "module": {"type": "string"},
        "callable": {"type": "string"},
        "command": {"type": "string"}
      },
      "additionalProperties": false
    },
    "supported_metrics": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "output_contract": {
      "type": "object",
      "required": ["writes_metrics_json", "writes_summary_markdown"],
      "properties": {
        "writes_metrics_json": {"type": "boolean"},
        "writes_summary_markdown": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "generated_at": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
