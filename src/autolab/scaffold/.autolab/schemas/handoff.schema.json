{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Handoff Snapshot",
  "description": "Machine-readable handoff and safe-resume snapshot.",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "state_file",
    "iteration_id",
    "experiment_id",
    "current_scope",
    "scope_root",
    "current_stage",
    "wave",
    "task_status",
    "latest_verifier_summary",
    "blocking_failures",
    "pending_human_decisions",
    "files_changed_since_last_green_point",
    "recommended_next_command",
    "safe_resume_point",
    "wave_observability",
    "last_green_at",
    "baseline_snapshot",
    "handoff_json_path",
    "handoff_markdown_path",
    "uat",
    "continuation_packet"
  ],
  "$defs": {
    "stringList": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "optionalTimestamp": {
      "type": "string"
    },
    "uatRequiredBy": {
      "type": "string",
      "enum": ["none", "policy", "plan_approval", "manual"]
    },
    "uatStatus": {
      "type": "string",
      "enum": ["not_required", "missing", "invalid", "pass", "needs_retry", "blocked"]
    },
    "planApprovalUat": {
      "type": "object",
      "required": ["policy_required", "effective_required", "required_by"],
      "properties": {
        "policy_required": {"type": "boolean"},
        "effective_required": {"type": "boolean"},
        "required_by": {"$ref": "#/$defs/uatRequiredBy"}
      },
      "additionalProperties": false
    },
    "uatSummary": {
      "type": "object",
      "required": [
        "required",
        "required_by",
        "artifact_path",
        "status",
        "pending",
        "pending_message",
        "suggested_init_command",
        "suggested_check_titles"
      ],
      "properties": {
        "required": {"type": "boolean"},
        "required_by": {"$ref": "#/$defs/uatRequiredBy"},
        "artifact_path": {"type": "string"},
        "status": {"$ref": "#/$defs/uatStatus"},
        "pending": {"type": "boolean"},
        "pending_message": {"type": "string"},
        "suggested_init_command": {"type": "string"},
        "suggested_check_titles": {"$ref": "#/$defs/stringList"}
      },
      "additionalProperties": false
    },
    "taskReasonCode": {
      "type": "string",
      "enum": [
        "completed",
        "dependency_blocked",
        "fail_fast_skipped",
        "wave_retry_pending",
        "runner_failed",
        "verification_failed",
        "expected_artifacts_missing",
        "out_of_contract_edits",
        "task_exception",
        "missing_task_result",
        "pending",
        "unknown"
      ]
    },
    "waveHeader": {
      "type": "object",
      "required": ["status", "current", "executed", "total"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["available", "unavailable"]
        },
        "current": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "executed": {
          "type": "integer",
          "minimum": 0
        },
        "total": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "taskSummary": {
      "type": "object",
      "required": [
        "status",
        "total",
        "completed",
        "failed",
        "blocked",
        "pending",
        "skipped",
        "deferred",
        "task_details"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["available", "unavailable"]
        },
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "completed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "blocked": {
          "type": "integer",
          "minimum": 0
        },
        "pending": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        },
        "deferred": {
          "type": "integer",
          "minimum": 0
        },
        "task_details": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": false
    },
    "latestVerifier": {
      "type": "object",
      "required": ["generated_at", "stage_effective", "passed", "message"],
      "properties": {
        "generated_at": {
          "$ref": "#/$defs/optionalTimestamp"
        },
        "stage_effective": {
          "type": "string"
        },
        "passed": {
          "type": ["boolean", "null"]
        },
        "message": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "commandRef": {
      "type": "object",
      "required": ["command", "reason", "executable"],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "executable": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "safeResume": {
      "type": "object",
      "required": ["command", "status", "preconditions"],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["ready", "blocked"]
        },
        "preconditions": {
          "$ref": "#/$defs/stringList"
        }
      },
      "additionalProperties": false
    },
    "artifactPointer": {
      "type": "object",
      "required": ["role", "path", "status", "reason", "inline_in_oracle"],
      "properties": {
        "role": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "status": {
          "type": "string",
          "enum": ["present", "missing", "invalid", "unknown"]
        },
        "reason": {"type": "string", "minLength": 1},
        "inline_in_oracle": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "activeStageSummary": {
      "type": "object",
      "required": [
        "stage",
        "stage_attempt",
        "max_stage_attempts",
        "scope_kind",
        "scope_root"
      ],
      "properties": {
        "stage": {"type": "string", "minLength": 1},
        "stage_attempt": {"type": "integer", "minimum": 0},
        "max_stage_attempts": {"type": "integer", "minimum": 0},
        "scope_kind": {
          "type": "string",
          "enum": ["experiment", "project_wide"]
        },
        "scope_root": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "nextActionSummary": {
      "type": "object",
      "required": [
        "recommended_command",
        "safe_command",
        "safe_status",
        "preconditions",
        "reason",
        "executable"
      ],
      "properties": {
        "recommended_command": {"type": "string", "minLength": 1},
        "safe_command": {"type": "string", "minLength": 1},
        "safe_status": {
          "type": "string",
          "enum": ["ready", "blocked"]
        },
        "preconditions": {"$ref": "#/$defs/stringList"},
        "reason": {"type": "string", "minLength": 1},
        "executable": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "latestGoodCheckpointSummary": {
      "type": "object",
      "required": [
        "checkpoint_id",
        "stage",
        "created_at",
        "last_green_at",
        "recommended_rewind_targets"
      ],
      "properties": {
        "checkpoint_id": {"type": "string"},
        "stage": {"type": "string"},
        "created_at": {"type": "string"},
        "last_green_at": {"type": "string"},
        "recommended_rewind_targets": {"$ref": "#/$defs/stringList"}
      },
      "additionalProperties": false
    },
    "policyAndRiskSummary": {
      "type": "object",
      "required": [
        "plan_approval_status",
        "plan_requires_approval",
        "plan_trigger_reasons",
        "plan_hash",
        "risk_fingerprint",
        "guardrail_breach",
        "block_reason",
        "context_rot_flags",
        "effective_flags"
      ],
      "properties": {
        "plan_approval_status": {"type": "string"},
        "plan_requires_approval": {"type": "boolean"},
        "plan_trigger_reasons": {"$ref": "#/$defs/stringList"},
        "plan_hash": {"type": "string"},
        "risk_fingerprint": {"type": "string"},
        "guardrail_breach": {"type": "string"},
        "block_reason": {"type": "string"},
        "context_rot_flags": {"$ref": "#/$defs/stringList"},
        "effective_flags": {"$ref": "#/$defs/stringList"}
      },
      "additionalProperties": false
    },
    "runStatusSummary": {
      "type": "object",
      "required": [
        "run_id",
        "host_mode",
        "manifest_status",
        "sync_status",
        "metrics_status",
        "manifest_path",
        "metrics_path"
      ],
      "properties": {
        "run_id": {"type": "string"},
        "host_mode": {"type": "string"},
        "manifest_status": {"type": "string"},
        "sync_status": {"type": "string"},
        "metrics_status": {"type": "string"},
        "manifest_path": {"type": "string"},
        "metrics_path": {"type": "string"}
      },
      "additionalProperties": false
    },
    "uatStatusSummary": {
      "type": "object",
      "required": [
        "required",
        "required_by",
        "status",
        "artifact_path",
        "pending",
        "pending_message",
        "suggested_init_command"
      ],
      "properties": {
        "required": {"type": "boolean"},
        "required_by": {"$ref": "#/$defs/uatRequiredBy"},
        "status": {"$ref": "#/$defs/uatStatus"},
        "artifact_path": {"type": "string"},
        "pending": {"type": "boolean"},
        "pending_message": {"type": "string"},
        "suggested_init_command": {"type": "string"}
      },
      "additionalProperties": false
    },
    "campaignSummary": {
      "type": "object",
      "properties": {
        "campaign_id": {"type": "string"},
        "label": {"type": "string"},
        "scope_kind": {"type": "string"},
        "iteration_id": {"type": "string"},
        "objective_metric": {"type": "string"},
        "objective_mode": {"type": "string"},
        "status": {"type": "string"},
        "design_locked": {"type": "boolean"},
        "harness_locked": {"type": "boolean"},
        "lock_mode": {"type": "string"},
        "lock_ok": {"type": "boolean"},
        "lock_drift": {"type": "string"},
        "lock_summary": {"type": "string"},
        "champion_run_id": {"type": "string"},
        "champion_revision_label": {"type": "string"},
        "no_improvement_streak": {"type": "integer", "minimum": 0},
        "crash_streak": {"type": "integer", "minimum": 0},
        "started_at": {"type": "string"},
        "last_oracle_at": {"type": "string"},
        "oracle_feedback_count": {"type": "integer", "minimum": 0},
        "resumable": {"type": "boolean"},
        "resume_error": {"type": "string"},
        "max_fix_attempts_per_idea": {"type": "integer", "minimum": 0},
        "max_timeout_factor": {"type": "number", "exclusiveMinimum": 0},
        "max_no_improvement_streak": {"type": "integer", "minimum": 1},
        "max_crash_streak_before_rethink": {"type": "integer", "minimum": 1},
        "active_candidate_decision": {"type": "string"},
        "active_candidate_started_at": {"type": "string"},
        "active_candidate_run_id": {"type": "string"},
        "active_candidate_fix_attempts": {"type": "integer", "minimum": 0},
        "active_candidate_timeout_reference_seconds": {
          "type": "number",
          "minimum": 0
        },
        "last_governance_event_at": {"type": "string"},
        "last_governance_event_category": {"type": "string"},
        "last_governance_event_run_id": {"type": "string"},
        "last_governance_event_reason": {"type": "string"}
      },
      "additionalProperties": false
    },
    "continuationPacket": {
      "type": "object",
      "required": [
        "schema_version",
        "generated_at",
        "active_stage",
        "next_action",
        "latest_good_checkpoint",
        "policy_and_risk",
        "run_status",
        "uat_status",
        "top_blockers",
        "artifact_pointers",
        "diagnostics"
      ],
      "properties": {
        "schema_version": {"type": "string", "const": "1.0"},
        "generated_at": {"$ref": "#/$defs/timestamp"},
        "active_stage": {"$ref": "#/$defs/activeStageSummary"},
        "next_action": {"$ref": "#/$defs/nextActionSummary"},
        "latest_good_checkpoint": {
          "$ref": "#/$defs/latestGoodCheckpointSummary"
        },
        "policy_and_risk": {"$ref": "#/$defs/policyAndRiskSummary"},
        "run_status": {"$ref": "#/$defs/runStatusSummary"},
        "uat_status": {"$ref": "#/$defs/uatStatusSummary"},
        "campaign": {"$ref": "#/$defs/campaignSummary"},
        "top_blockers": {"$ref": "#/$defs/stringList"},
        "artifact_pointers": {
          "type": "array",
          "items": {"$ref": "#/$defs/artifactPointer"}
        },
        "diagnostics": {"$ref": "#/$defs/stringList"}
      },
      "additionalProperties": false
    },
    "planApproval": {
      "type": "object",
      "required": [
        "schema_version",
        "generated_at",
        "iteration_id",
        "status",
        "requires_approval",
        "plan_hash",
        "risk_fingerprint",
        "trigger_reasons",
        "counts",
        "reviewed_by",
        "reviewed_at",
        "notes",
        "source_paths",
        "uat"
      ],
      "properties": {
        "schema_version": {"type": "string", "const": "1.0"},
        "generated_at": {"$ref": "#/$defs/timestamp"},
        "iteration_id": {"type": "string", "minLength": 1},
        "status": {
          "type": "string",
          "enum": ["not_required", "pending", "approved", "retry", "stop", "superseded"]
        },
        "requires_approval": {"type": "boolean"},
        "plan_hash": {"type": "string", "minLength": 1},
        "risk_fingerprint": {"type": "string", "minLength": 1},
        "trigger_reasons": {"$ref": "#/$defs/stringList"},
        "counts": {
          "type": "object",
          "required": [
            "tasks_total",
            "waves_total",
            "project_wide_tasks",
            "project_wide_unique_paths",
            "observed_retries",
            "stage_attempt"
          ],
          "properties": {
            "tasks_total": {"type": "integer", "minimum": 0},
            "waves_total": {"type": "integer", "minimum": 0},
            "project_wide_tasks": {"type": "integer", "minimum": 0},
            "project_wide_unique_paths": {"type": "integer", "minimum": 0},
            "observed_retries": {"type": "integer", "minimum": 0},
            "stage_attempt": {"type": "integer", "minimum": 0}
          },
          "additionalProperties": false
        },
        "reviewed_by": {"type": "string"},
        "reviewed_at": {"type": "string"},
        "notes": {"type": "string"},
        "source_paths": {
          "type": "object",
          "required": ["plan_contract", "plan_graph", "plan_check_result"],
          "properties": {
            "plan_contract": {"type": "string", "minLength": 1},
            "plan_graph": {"type": "string", "minLength": 1},
            "plan_check_result": {"type": "string", "minLength": 1}
          },
          "additionalProperties": false
        },
        "uat": {
          "$ref": "#/$defs/planApprovalUat"
        }
      },
      "additionalProperties": false
    },
    "waveAttempt": {
      "type": "object",
      "required": [
        "attempt",
        "status",
        "started_at",
        "completed_at",
        "duration_seconds",
        "retry_reason",
        "detail"
      ],
      "properties": {
        "attempt": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": ["pending", "completed", "failed", "blocked"]
        },
        "started_at": {
          "$ref": "#/$defs/optionalTimestamp"
        },
        "completed_at": {
          "$ref": "#/$defs/optionalTimestamp"
        },
        "duration_seconds": {
          "type": "number",
          "minimum": 0
        },
        "retry_reason": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "evidenceSummary": {
      "type": "object",
      "required": [
        "runner_status",
        "runner_exit_code",
        "verification_status",
        "files_changed_count",
        "expected_artifacts_missing_count",
        "text"
      ],
      "properties": {
        "runner_status": {
          "type": "string"
        },
        "runner_exit_code": {
          "type": ["integer", "null"]
        },
        "verification_status": {
          "type": "string"
        },
        "files_changed_count": {
          "type": "integer",
          "minimum": 0
        },
        "expected_artifacts_missing_count": {
          "type": "integer",
          "minimum": 0
        },
        "text": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "waveTaskDetail": {
      "type": "object",
      "required": [
        "task_id",
        "status",
        "wave",
        "attempts",
        "retries_used",
        "last_error",
        "scope_kind",
        "files_changed",
        "started_at",
        "completed_at",
        "duration_seconds",
        "timing_available",
        "reason_code",
        "reason_detail",
        "blocked_by",
        "runner_report_path",
        "runner_status",
        "runner_exit_code",
        "verification_status",
        "verification_commands",
        "expected_artifacts_missing",
        "evidence_summary",
        "critical_path"
      ],
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["pending", "completed", "failed", "blocked"]
        },
        "wave": {
          "type": "integer",
          "minimum": 1
        },
        "attempts": {
          "type": "integer",
          "minimum": 0
        },
        "retries_used": {
          "type": "integer",
          "minimum": 0
        },
        "last_error": {
          "type": "string"
        },
        "scope_kind": {
          "type": "string"
        },
        "files_changed": {
          "$ref": "#/$defs/stringList"
        },
        "started_at": {
          "$ref": "#/$defs/optionalTimestamp"
        },
        "completed_at": {
          "$ref": "#/$defs/optionalTimestamp"
        },
        "duration_seconds": {
          "type": "number",
          "minimum": 0
        },
        "timing_available": {
          "type": "boolean"
        },
        "reason_code": {
          "$ref": "#/$defs/taskReasonCode"
        },
        "reason_detail": {
          "type": "string"
        },
        "blocked_by": {
          "$ref": "#/$defs/stringList"
        },
        "runner_report_path": {
          "type": "string"
        },
        "runner_status": {
          "type": "string"
        },
        "runner_exit_code": {
          "type": ["integer", "null"]
        },
        "verification_status": {
          "type": "string"
        },
        "verification_commands": {
          "$ref": "#/$defs/stringList"
        },
        "expected_artifacts_missing": {
          "$ref": "#/$defs/stringList"
        },
        "evidence_summary": {
          "$ref": "#/$defs/evidenceSummary"
        },
        "critical_path": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "waveDetail": {
      "type": "object",
      "required": [
        "wave",
        "status",
        "attempts",
        "retries_used",
        "tasks",
        "started_at",
        "completed_at",
        "duration_seconds",
        "last_attempt_duration_seconds",
        "timing_available",
        "attempt_history",
        "retry_reasons",
        "current_retry_reasons",
        "out_of_contract_paths",
        "completed_task_ids",
        "failed_task_ids",
        "blocked_task_ids",
        "skipped_task_ids",
        "deferred_task_ids",
        "pending_task_ids",
        "retry_pending",
        "critical_path"
      ],
      "properties": {
        "wave": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": ["pending", "completed", "failed", "blocked"]
        },
        "attempts": {
          "type": "integer",
          "minimum": 0
        },
        "retries_used": {
          "type": "integer",
          "minimum": 0
        },
        "tasks": {
          "$ref": "#/$defs/stringList"
        },
        "started_at": {
          "$ref": "#/$defs/optionalTimestamp"
        },
        "completed_at": {
          "$ref": "#/$defs/optionalTimestamp"
        },
        "duration_seconds": {
          "type": "number",
          "minimum": 0
        },
        "last_attempt_duration_seconds": {
          "type": "number",
          "minimum": 0
        },
        "timing_available": {
          "type": "boolean"
        },
        "attempt_history": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/waveAttempt"
          }
        },
        "retry_reasons": {
          "$ref": "#/$defs/stringList"
        },
        "current_retry_reasons": {
          "$ref": "#/$defs/stringList"
        },
        "out_of_contract_paths": {
          "$ref": "#/$defs/stringList"
        },
        "completed_task_ids": {
          "$ref": "#/$defs/stringList"
        },
        "failed_task_ids": {
          "$ref": "#/$defs/stringList"
        },
        "blocked_task_ids": {
          "$ref": "#/$defs/stringList"
        },
        "skipped_task_ids": {
          "$ref": "#/$defs/stringList"
        },
        "deferred_task_ids": {
          "$ref": "#/$defs/stringList"
        },
        "pending_task_ids": {
          "$ref": "#/$defs/stringList"
        },
        "retry_pending": {
          "type": "boolean"
        },
        "critical_path": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "criticalPath": {
      "type": "object",
      "required": [
        "status",
        "mode",
        "task_ids",
        "wave_ids",
        "duration_seconds",
        "weight",
        "basis_note"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["available", "unavailable"]
        },
        "mode": {
          "type": "string",
          "enum": [
            "structural",
            "measured_partial",
            "measured_complete",
            "unavailable"
          ]
        },
        "task_ids": {
          "$ref": "#/$defs/stringList"
        },
        "wave_ids": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "duration_seconds": {
          "type": "number",
          "minimum": 0
        },
        "weight": {
          "type": "number",
          "minimum": 0
        },
        "basis_note": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "fileConflict": {
      "type": "object",
      "required": [
        "kind",
        "wave",
        "tasks",
        "paths",
        "conflict_group",
        "detail"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "same_wave_write_conflict",
            "same_wave_conflict_group_collision",
