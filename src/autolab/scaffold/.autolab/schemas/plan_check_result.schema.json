{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Implementation Plan Check Result",
  "description": "Checker output for implementation plan contract validation.",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "stage",
    "iteration_id",
    "passed",
    "error_count",
    "warning_count",
    "errors",
    "warnings",
    "rule_results",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string",
      "const": "implementation"
    },
    "iteration_id": {
      "type": "string",
      "minLength": 1
    },
    "passed": {
      "type": "boolean"
    },
    "error_count": {
      "type": "integer",
      "minimum": 0
    },
    "warning_count": {
      "type": "integer",
      "minimum": 0
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rule_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rule",
          "status",
          "detail"
        ],
        "properties": {
          "rule": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "fail",
              "warn"
            ]
          },
          "detail": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "object",
      "required": [
        "contract_path",
        "snapshot_path",
        "plan_check_result_path",
        "plan_graph_path"
      ],
      "properties": {
        "contract_path": {
          "type": "string",
          "minLength": 1
        },
        "snapshot_path": {
          "type": "string",
          "minLength": 1
        },
        "plan_check_result_path": {
          "type": "string",
          "minLength": 1
        },
        "plan_graph_path": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
