{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ParserCapabilitiesIndex",
  "type": "object",
  "required": ["schema_version", "generated_at", "iterations"],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "generated_at": {"type": "string", "minLength": 1},
    "iterations": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "manifest_path",
          "parser_kind",
          "supported_metrics",
          "updated_at"
        ],
        "properties": {
          "manifest_path": {"type": "string", "minLength": 1},
          "parser_kind": {"type": "string", "enum": ["python", "command"]},
          "supported_metrics": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "updated_at": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
