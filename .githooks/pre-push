#!/usr/bin/env sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if [ -n "${VIRTUAL_ENV:-}" ] && [ -x "${VIRTUAL_ENV}/bin/python" ]; then
  python_bin="${VIRTUAL_ENV}/bin/python"
elif [ -x "${repo_root}/.venv/bin/python" ]; then
  python_bin="${repo_root}/.venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
  python_bin="python3"
elif command -v python >/dev/null 2>&1; then
  python_bin="python"
else
  echo "pre-push: ERROR python interpreter not found" >&2
  exit 1
fi

if [ "${AUTOLAB_SKIP_PYTEST:-0}" = "1" ] || [ "${AUTOLAB_SKIP_TESTS:-0}" = "1" ]; then
  echo "pre-push: skipping pytest (AUTOLAB_SKIP_PYTEST or AUTOLAB_SKIP_TESTS enabled)"
  exit 0
fi

echo "pre-push: running pytest"
if ! "$python_bin" -m pytest; then
  echo "pre-push: pytest failed"
  exit 1
fi

echo "pre-push: pytest passed"
